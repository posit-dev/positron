{
	"name": "authentication",
	"displayName": "Authentication",
	"description": "Centralized credential management",
	"version": "0.0.1",
	"publisher": "positron",
	"private": true,
	"engines": {
		"vscode": "^1.108.0"
	},
	"activationEvents": [
		"onStartupFinished",
		"onAuthenticationRequest:anthropic-api",
		"onAuthenticationRequest:posit-ai",
		"onAuthenticationRequest:ms-foundry",
		"onAuthenticationRequest:amazon-bedrock",
		"onAuthenticationRequest:snowflake-cortex",
		"onAuthenticationRequest:openai-api",
		"onAuthenticationRequest:openai-compatible",
		"onAuthenticationRequest:google",
		"onAuthenticationRequest:google-cloud",
		"onAuthenticationRequest:deepseek-api",
		"onCommand:authentication.configureProviders",
		"onCommand:authentication.migrateApiKey"
	],
	"main": "./out/extension.js",
	"dependencies": {
		"@aws-sdk/credential-providers": "^3.734.0",
		"@aws-sdk/types": "^3.734.0",
		"google-auth-library": "^9.15.1"
	},
	"devDependencies": {
		"@types/node": "22.x"
	},
	"contributes": {
		"authentication": [
			{
				"id": "anthropic-api",
				"label": "Anthropic"
			},
			{
				"id": "posit-ai",
				"label": "Posit AI"
			},
			{
				"id": "ms-foundry",
				"label": "Microsoft Foundry"
			},
			{
				"id": "amazon-bedrock",
				"label": "AWS"
			},
			{
				"id": "snowflake-cortex",
				"label": "Snowflake Cortex"
			},
			{
				"id": "openai-api",
				"label": "OpenAI"
			},
			{
				"id": "openai-compatible",
				"label": "Custom Provider"
			},
			{
				"id": "google",
				"label": "Gemini Code Assist"
			},
			{
				"id": "google-cloud",
				"label": "Google Vertex AI"
			},
			{
				"id": "deepseek-api",
				"label": "DeepSeek"
			}
		],
		"commands": [
			{
				"command": "authentication.configureProviders",
				"title": "%commands.configureProviders.title%",
				"category": "%commands.category%"
			}
		],
		"configuration": {
			"title": "Authentication",
			"properties": {
				"authentication.aws.credentials": {
					"type": "object",
					"default": {},
					"markdownDescription": "%configuration.aws.credentials.description%",
					"properties": {
						"AWS_PROFILE": {
							"type": "string",
							"default": null
						},
						"AWS_REGION": {
							"type": "string",
							"default": null
						}
					},
					"additionalProperties": false
				},
				"authentication.aws.inferenceProfileRegion": {
					"type": "string",
					"default": null,
					"markdownDescription": "%configuration.aws.inferenceProfileRegion.description%"
				},
				"authentication.snowflake.credentials": {
					"type": "object",
					"default": {},
					"markdownDescription": "%configuration.snowflake.credentials.description%",
					"properties": {
						"SNOWFLAKE_ACCOUNT": {
							"type": "string",
							"default": null
						},
						"SNOWFLAKE_HOME": {
							"type": "string",
							"default": null
						}
					},
					"additionalProperties": false
				},
				"authentication.snowflake.customHeaders": {
					"type": "object",
					"default": {},
					"additionalProperties": {
						"type": "string"
					},
					"markdownDescription": "%configuration.snowflake.customHeaders.description%",
					"tags": [
						"preview"
					]
				},
				"authentication.anthropic.baseUrl": {
					"type": "string",
					"default": "",
					"description": "%configuration.anthropic.baseUrl.description%"
				},
				"authentication.anthropic.customHeaders": {
					"type": "object",
					"default": {},
					"additionalProperties": {
						"type": "string"
					},
					"markdownDescription": "%configuration.anthropic.customHeaders.description%",
					"tags": [
						"preview"
					]
				},
				"authentication.foundry.baseUrl": {
					"type": "string",
					"default": "",
					"description": "%configuration.foundry.baseUrl.description%",
					"tags": [
						"preview"
					]
				},
				"authentication.foundry.customHeaders": {
					"type": "object",
					"default": {},
					"additionalProperties": {
						"type": "string"
					},
					"markdownDescription": "%configuration.foundry.customHeaders.description%",
					"tags": [
						"preview"
					]
				},
				"authentication.openai-api.baseUrl": {
					"type": "string",
					"default": "",
					"description": "%configuration.openai-api.baseUrl.description%"
				},
				"authentication.openai-api.customHeaders": {
					"type": "object",
					"default": {},
					"additionalProperties": {
						"type": "string"
					},
					"markdownDescription": "%configuration.openai-api.customHeaders.description%",
					"tags": [
						"preview"
					]
				},
				"authentication.google.baseUrl": {
					"type": "string",
					"default": "",
					"description": "%configuration.google.baseUrl.description%",
					"tags": [
						"experimental",
						"advanced"
					]
				},
				"authentication.google.customHeaders": {
					"type": "object",
					"default": {},
					"additionalProperties": {
						"type": "string"
					},
					"markdownDescription": "%configuration.google.customHeaders.description%",
					"tags": [
						"experimental",
						"advanced"
					]
				},
				"authentication.googleVertex.baseUrl": {
					"type": "string",
					"default": "",
					"description": "%configuration.googleVertex.baseUrl.description%",
					"tags": [
						"experimental"
					]
				},
				"authentication.googleVertex.credentials": {
					"type": "object",
					"default": {},
					"markdownDescription": "%configuration.googleVertex.credentials.description%",
					"properties": {
						"GOOGLE_VERTEX_PROJECT": {
							"type": "string",
							"default": null
						},
						"GOOGLE_VERTEX_LOCATION": {
							"type": "string",
							"default": null
						}
					},
					"additionalProperties": false,
					"tags": [
						"experimental"
					]
				},
				"authentication.googleVertex.customHeaders": {
					"type": "object",
					"default": {},
					"additionalProperties": {
						"type": "string"
					},
					"markdownDescription": "%configuration.googleVertex.customHeaders.description%",
					"tags": [
						"experimental"
					]
				},
				"authentication.openai-compatible.baseUrl": {
					"type": "string",
					"default": "",
					"description": "%configuration.openai-compatible.baseUrl.description%",
					"tags": [
						"experimental"
					]
				},
				"authentication.openai-compatible.customHeaders": {
					"type": "object",
					"default": {},
					"additionalProperties": {
						"type": "string"
					},
					"markdownDescription": "%configuration.openai-compatible.customHeaders.description%",
					"tags": [
						"experimental"
					]
				},
				"authentication.deepseek-api.baseUrl": {
					"type": "string",
					"default": "",
					"description": "%configuration.deepseek-api.baseUrl.description%",
					"tags": [
						"experimental"
					]
				},
				"authentication.deepseek-api.customHeaders": {
					"type": "object",
					"default": {},
					"additionalProperties": {
						"type": "string"
					},
					"markdownDescription": "%configuration.deepseek-api.customHeaders.description%",
					"tags": [
						"experimental"
					]
				},
				"assistant.provider.googleVertex.enabled": {
					"type": "boolean",
					"default": true,
					"markdownDescription": "%configuration.provider.googleVertex.enabled.description%",
					"tags": [
						"experimental"
					]
				},
				"assistant.provider.deepseek.enabled": {
					"type": "boolean",
					"default": true,
					"markdownDescription": "%configuration.provider.deepseek.enabled.description%",
					"tags": [
						"experimental"
					]
				}
			}
		}
	}
}
