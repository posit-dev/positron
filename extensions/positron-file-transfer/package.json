{
  "name": "positron-file-transfer",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "publisher": "positron",
  "private": true,
  "engines": {
    "vscode": "^1.65.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": [
      {
        "type": "object",
        "title": "%fileTransfer.configuration.title%",
        "properties": {
          "fileTransfer.showNotifications": {
            "scope": "window",
            "type": "boolean",
            "default": true,
            "description": "%fileTransfer.configuration.showNotifications.description%"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "14.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/posit-dev/positron"
  }
}
