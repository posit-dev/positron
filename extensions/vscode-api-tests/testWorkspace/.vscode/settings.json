{
	"search.exclude": {
		"**/search-exclude/**": true
	},
	"files.exclude": {
		"**/files-exclude/**": true
	},
	"editor.minimap.enabled": false, // see https://github.com/microsoft/vscode/issues/115747
	"workbench.editor.languageDetection": true,
	"typescript.disableAutomaticTypeAcquisition": true,
	"json.schemaDownload.enable": false,
	"npm.fetchOnlinePackageInfo": false,
	"npm.autoDetect": "off",
	// --- Start Positron ---
	// Enable the test lm vendor for testing purposes
	"positron.assistant.provider.testLmVendor.enable": true,
	// Enable GitHub Copilot provider for chat participant tests
	"positron.assistant.provider.githubCopilot.enable": true,
	// These upstream VS Code API contract tests exercise the legacy (VS Code)
	// notebook editor. The Positron notebook editor is now the default, so keep
	// it disabled here so these tests continue testing the legacy editor.
	"positron.notebook.enabled": false,
	// --- End Positron ---
	"workbench.localHistory.enabled": false
}
