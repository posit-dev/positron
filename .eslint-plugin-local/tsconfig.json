{
	"compilerOptions": {
		"target": "es2024",
		"lib": [
			"ES2024"
		],
		"rootDir": ".",
		"module": "esnext",
		// --- Start Positron ---
		// Required so TS can resolve packages like @typescript-eslint/utils that
		// use the 'exports' field in package.json. 'nodenext' would also work but
		// enforces file extensions on relative imports.
		"moduleResolution": "bundler",
		// --- End Positron ---
		"allowImportingTsExtensions": true,
		"erasableSyntaxOnly": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"strict": true,
		"exactOptionalPropertyTypes": false,
		"useUnknownInCatchVariables": false,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"typeRoots": [
			"."
		]
	},
	"include": [
		"**/*.ts",
		// --- Start Positron ---
		"**/*.tsx",
		// --- End Positron ---
	],
	"exclude": [
		"node_modules/**",
		"./tests/**"
	]
}
