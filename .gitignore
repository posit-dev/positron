# --- Start Positron ---
# Positron maintains a custom codicon.ttf that includes Positron-specific icons.
# Do not gitignore it (upstream does because they copy from the npm package).
# src/vs/base/browser/ui/codicons/codicon/codicon.ttf
# --- End Positron ---
/out*/
/extensions/**/out/
build/node_modules
build/darwin/.dmgbuild
coverage/
test_data/
test-results/
test-results.xml
vscode.lsif
vscode.db
/.profile-oss
tags
/cli/target
/cli/openssl
product.overrides.json
*.snap.actual
*.tsbuildinfo
.eslintcache
.vscode-test
.chat-simulation-data
vscode-telemetry-docs/
pwb-version
# --- Start Positron ---
# Ignore Claude local/personal files but keep commands
.claude/*
!.claude/commands/
!.claude/skills/
!.claude/hooks/
!.claude/rules/
!.claude/settings.json
