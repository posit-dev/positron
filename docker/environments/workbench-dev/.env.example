# Copy to docker/environments/workbench-dev/.env and fill in. Required values are prompted if missing.
E2E_POSTGRES_USER=testuser
E2E_POSTGRES_PASSWORD=testpassword
WB_PASSWORD=testpassword
#
# Managed credentials (only needed with `npm run pwb -- --credentials=<type>`).
# Fill in the set for the provider you want, then run with that --credentials flag.
# Values live in the team 1Password vault. Keep the single quotes: this file is
# sourced by the shell, so a secret with a $, space, or # in it breaks without them.
# The trailing underscore is optional locally -- the bare names (SNOWFLAKE_ACCOUNT,
# as they appear in 1Password / GitHub secrets) are accepted as aliases.
# databricks:
# DATABRICKS_URL_=''
# DATABRICKS_CLIENT_ID_=''
# snowflake:
# SNOWFLAKE_ACCOUNT_=''
# SNOWFLAKE_CLIENT_ID_=''
# SNOWFLAKE_CLIENT_SECRET_=''
# azure:
# AZURE_SERVICE_PRINCIPAL_CLIENT_SECRET_=''
