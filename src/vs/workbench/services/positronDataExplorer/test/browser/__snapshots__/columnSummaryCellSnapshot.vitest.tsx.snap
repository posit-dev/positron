exports[`ColumnSummaryCell - Snapshot & RTL > snapshots > matches snapshot for 100% null column 1`] = `"<div class="column-summary"><div class="cursor-indicator"></div><div class="basic-info"><div class="expand-collapse-button"><div class="expand-collapse-icon codicon codicon-chevron-right"></div></div><div class="data-type-icon codicon codicon-positron-data-type-string"></div><div class="column-name">empty_col</div><div class="column-sparkline" style="width: 80px; height: 20.5px;"><svg class="vector-histogram loading-sparkline" shape-rendering="crispEdges" viewBox="0 0 80 20.5"><g><rect class="x-axis" height="0.5" width="80" x="0" y="19.5"></rect><rect class="loading-indicator" height="6" rx="2" width="64" x="8" y="10"></rect></g></svg></div><div class="column-null-percent"><div class="text-percent">100%</div><div class="graph-percent"><svg shape-rendering="geometricPrecision" viewBox="0 0 52 14"><defs><clipPath id="clip-indicator"><rect height="12" rx="6" ry="6" width="50" x="1" y="1"></rect></clipPath></defs><g><rect class="background" height="12" rx="6" ry="6" stroke-width="1" width="50" x="1" y="1"></rect><rect class="indicator" clip-path="url(#clip-indicator)" height="12" rx="6" ry="6" width="0" x="1" y="1"></rect></g></svg></div></div></div></div>"`;

