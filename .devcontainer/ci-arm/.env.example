# .devcontainer/ci-arm/.env.example — copy to .env and fill from 1Password.
# (Positron > E2E Postgres DB Connection info; license from IDE/Workbench vault.)
# This file must live next to docker-compose.yml so Compose auto-loads it.
E2E_POSTGRES_USER=testuser
E2E_POSTGRES_PASSWORD=testpassword
# NOTE: the dev license is a multi-line PEM key — do NOT put it here (a .env file can't hold
# newlines). Instead save it to .devcontainer/ci-arm/license.txt (gitignored); post-create.sh
# installs it for you.
# Pin a specific CI image tag (default tracks CI):
POSITRON_CI_IMAGE_TAG=127
# Image architecture: arm64 (Apple Silicon, validated) or amd64 (Windows/Intel; experimental,
# requires an amd64 image to be published — not available as of this writing):
POSITRON_CI_IMAGE_ARCH=arm64

# Auto-detected by initialize.sh on container start — do not set these by hand:
#   POSITRON_WORKSPACE_PATH  (host path of your checkout)
#   POSITRON_GIT_COMMON_DIR  (host path of the repo's git dir; makes worktrees work)
